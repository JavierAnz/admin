---
import Layout from "../layouts/Layout.astro";
import AdminNavbar from "../components/AdminNavbar.astro";
import Buscador from "../components/inventario/Buscador.svelte";
import SpeedInsights from "@vercel/speed-insights/astro";

const agenciaId = Astro.locals.user?.agenciaId ?? Astro.cookies.get("agencia_id")?.value;
const nombreAgencia = Astro.locals.user?.agenciaNombre ?? "";
---

<Layout title="Inventario | OFIT">
  <div class="inventario-page">
    <AdminNavbar />
    <SpeedInsights sampleRate={0.1} />
    <Buscador
      client:load
      idAgenciaUsuario={agenciaId}
      nombreAgencia={nombreAgencia}
    />
  </div>
</Layout>

<style is:global>
  .inventario-page {
    min-height: 100vh;
    background: #f8fafc;
  }
</style>
